# ─── Database ────────────────────────────────────────────────────────────────
# Local development (matches docker-compose.yml defaults)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/opportunity_tracker

# Production example (Railway / Render / Supabase)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ─── AI (Google Gemini — free tier) ──────────────────────────────────────────
# Get your free API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── App Settings ─────────────────────────────────────────────────────────────
APP_ENV=development          # development | production | test
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# ─── Scheduler ────────────────────────────────────────────────────────────────
# Time (UTC) to run the daily pipeline
PIPELINE_RUN_HOUR=6
PIPELINE_RUN_MINUTE=0

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000
